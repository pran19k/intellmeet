{
  "name": "intellimeet",
  "private": true,
  "version": "0.1.0",
  "description": "IntelliMeet monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:api": "npm run dev -w @intellimeet/api",
    "dev:web": "npm run dev -w @intellimeet/web",
    "dev:socket": "node apps/socket/src/server.js",
    "dev:worker": "node apps/worker/src/worker.js",
    "smoke:api": "node scripts/test_refresh.js && node scripts/smoke_test.js && node scripts/smoke_persist.js && node scripts/smoke_check_persist.js",
    "smoke:socket": "node scripts/smoke_socket_presence.js",
    "smoke:messages": "node scripts/test_messages_api.js",
    "test:socket": "node scripts/test_socket_integration.js",
    "check": "node scripts/check.js"
  }
}
